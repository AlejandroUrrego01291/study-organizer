generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// USUARIO
// ─────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Configuración de compromiso de estudio
  dailyGoalHours   Float @default(1)
  monthlyGoalHours Float @default(20)
  annualGoalHours  Float @default(240)

  // Configuración Pomodoro
  pomodoroMinutes      Int @default(25)
  shortBreakMinutes    Int @default(5)
  longBreakMinutes     Int @default(20)
  sessionsBeforeLong   Int @default(4)

  // Relaciones
  cards        Card[]
  categories   Category[]
  series       Series[]
  badges       UserBadge[]
  certificates Certificate[]
  sessions     StudySession[]

  @@map("users")
}

// ─────────────────────────────────────────
// CATEGORÍAS (configurables por usuario)
// ─────────────────────────────────────────
model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cards Card[]

  @@unique([userId, name])
  @@map("categories")
}

// ─────────────────────────────────────────
// SERIES (configurables por usuario)
// ─────────────────────────────────────────
model Series {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cards Card[]

  @@unique([userId, name])
  @@map("series")
}

// ─────────────────────────────────────────
// TARJETA DE ESTUDIO
// ─────────────────────────────────────────
model Card {
  id        String     @id @default(cuid())
  title     String
  status    CardStatus @default(DO)
  studyType StudyType  @default(VIDEO)

  // Progreso manual
  currentMinute Int?    // Para video/audio
  currentPage   Int?    // Para texto

  // Info opcional
  resourceUrl String?  // Enlace del video/recurso
  source      String?  // Fuente de estudio (texto libre)
  notes       String?  // Notas adicionales

  // Timestamps automáticos
  createdAt   DateTime  @default(now())
  startedAt   DateTime?             // Primera vez que se dio iniciar
  lastActiveAt DateTime?            // Última vez que se activó el cronómetro
  completedAt DateTime?             // Cuando pasó a Done

  // Tiempo acumulado total en segundos
  totalStudySeconds Int @default(0)

  // Pomodoro config por tarjeta (hereda del usuario si es null)
  pomodoroMinutes Int?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  seriesId String?
  series   Series?  @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  studySessions StudySession[]

  @@map("cards")
}

// ─────────────────────────────────────────
// SESIONES DE ESTUDIO (cada bloque cronometrado)
// ─────────────────────────────────────────
model StudySession {
  id        String   @id @default(cuid())
  startedAt DateTime @default(now())
  endedAt   DateTime?
  durationSeconds Int @default(0) // Duración real de la sesión

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_sessions")
}

// ─────────────────────────────────────────
// CERTIFICACIONES
// ─────────────────────────────────────────
model Certificate {
  id          String   @id @default(cuid())
  name        String
  fileUrl     String   // URL en Supabase Storage
  fileName    String
  fileSize    Int      // en bytes
  issuedAt    DateTime?
  createdAt   DateTime @default(now())

  // Metadata
  seriesName   String?
  categoryName String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ─────────────────────────────────────────
// INSIGNIAS DEL SISTEMA
// ─────────────────────────────────────────
model Badge {
  id          String    @id @default(cuid())
  key         BadgeKey  @unique
  name        String
  description String
  icon        String    // emoji o nombre de icono

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  earnedAt DateTime @default(now())
  count    Int      @default(1) // Para insignias acumulables (estrellas)

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────
enum CardStatus {
  DO
  DOING
  DONE
}

enum StudyType {
  VIDEO
  AUDIO
  TEXT
}

enum BadgeKey {
  STAR         // 1 estrella por hora de estudio
  MEDAL        // Medalla por serie/tema terminado
  TROPHY       // Trofeo por 60 horas
  EPIC_LION    // León épico por 720 horas
}